# .env.ci
# Minimal environment for GitHub Actions CI.
# No real API keys — LLM-dependent code paths fall back to rule-based logic.
# No database URLs — connector tests use monkeypatch to skip connection probing.

# ── LLM (leave blank → rule-based fallback is used) ──────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Security / policy ─────────────────────────────────────
INTERNET_OFF_MODE=false
LOCAL_LLM_MODE=false

# ── Analysis defaults ─────────────────────────────────────
DEFAULT_ROLLING_WINDOW=7
DEFAULT_Z_THRESHOLD=2.0
DEFAULT_DRIVER_DAYS=3
MAX_QUERY_ROWS=100000

# ── Scheduler (disabled in CI) ───────────────────────────
ENABLE_SCHEDULER=false

# ── Vector backend (disabled in CI — no chromadb install) ─
VECTOR_BACKEND=none

# ── Multi-tenant API ──────────────────────────────────────
JWT_SECRET=ci-test-secret-not-for-production
